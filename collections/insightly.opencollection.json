{
  "opencollection": "1.0.0",
  "info": {
    "name": "Insightly CRM API",
    "version": "3.1"
  },
  "request": {
    "auth": {
      "type": "basic",
      "username": "{{username}}",
      "password": "{{password}}"
    }
